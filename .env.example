# The Frame — server-side env vars, consumed by server.ts (prod) and the Vite
# dev-server API plugin. Copy to .env and edit to override. Values below are the
# in-code defaults.

# Prod server port (server.ts). The Vite dev server also reads PORT (vite.config.ts).
# Single app on 7375 — no dev/prod split.
PORT=7375

# Image store: on-disk blobs + JSON sidecar metadata (no SQL).
FRAME_GALLERY_DIR=./frame-gallery

# Calendar store: SQLite DB file (separate from the image store).
FRAME_CALENDAR_DB=./frame-calendar.db

# LAN host baked into the printable QR by `npm run qr`. Required for QR
# generation (no auto-detection) — set to this machine's LAN IP or hostname.
FRAME_LAN_HOST=192.168.1.50
